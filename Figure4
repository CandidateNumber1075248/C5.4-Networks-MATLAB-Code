clc
clf
clear all
close all
set(0,'DefaultAxesFontSize',25);
set(0,'DefaultAxesFontName','Times New Roman');

%Setting the range of parameters to be used
p_values=[0.1,0.3,0.5,0.7,0.9];
N_values=round(linspace(100,1000,30));

%Number of trials to take the mean over
trials=1000;

%Empty matrices to store data for r across parameter space
r_values=zeros(length(p_values),length(N_values));
r_temp=zeros(trials,1);

for i=1:length(p_values)

    for j=1:length(N_values)

        for n=1:trials

            %Generating the adjacency matrix for the network
            A=aon_network(N_values(j),p_values(i));

            %Calculating r from the adjacency matrix
            r_temp(n)=assortativity(A);

        end

        %Taking the mean over simulations
        r_values(i,j)=mean(r_temp);

    end
end

figure;
hold on;

%Plot r against N for each p-value
for j = 1:length(p_values)
    plot(N_values, r_values(j,:),'LineWidth',2);
end

xlabel('Network size, N')
ylabel('Assortativity Coefficient, r')
title('Figure 4')
legend('p=0.1','p=0.3','p=0.5','p=0.7','p=0.9','Location','best')
grid on

%Function to calculate the assortativity coefficient from the adjacency
%matrix
function r=assortativity(A)

    %Count every undirected edge in the network 
    A=double(A);
    k=sum(A,2);
    [i,j]=find(triu(A,1));

    %Assign degree values
    ki=k(i);
    kj=k(j);

    %Calculate assortativity coefficient
    mean_kk=mean(ki.*kj);
    mean_k=mean((ki+kj)/2);
    mean_k2=mean((ki.^2+kj.^2)/2);
    r=(mean_kk-mean_k^2)/(mean_k2-mean_k^2);

end
